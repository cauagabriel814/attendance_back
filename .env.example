# ─────────────────────────────────────────────
# BANCO DE DADOS
# ─────────────────────────────────────────────
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/attendance_db?schema=public"

# ─────────────────────────────────────────────
# APP
# ─────────────────────────────────────────────
NODE_ENV=development
PORT=3000
FRONTEND_URL=http://localhost:5173

# ─────────────────────────────────────────────
# JWT
# ─────────────────────────────────────────────
JWT_ACCESS_SECRET=minimum_64_char_random_secret_for_access_tokens_here
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_SECRET=minimum_64_char_random_secret_for_refresh_tokens_here
JWT_REFRESH_EXPIRES_IN=7d

# ─────────────────────────────────────────────
# CRIPTOGRAFIA (CPF — AES-256-CBC, exatamente 32 chars)
# ─────────────────────────────────────────────
ENCRYPTION_KEY=exactly_32_characters_long_key!!

# ─────────────────────────────────────────────
# E-MAIL (Gmail App Password)
# ─────────────────────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=seu_email@gmail.com
EMAIL_APP_PASSWORD=sua_senha_de_app_gmail
EMAIL_FROM="Controle de Ponto <seu_email@gmail.com>"
